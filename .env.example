# ══════════════════════════════════════════════════════════════════
#  JITO Green Legacy — Environment Variables
#  Copy this file to .env.local for local development
#  Set all variables in Vercel Dashboard → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════════

# ── Database (Supabase) ───────────────────────────────────────────
# Supabase: Project Settings → Database → Connection string
# Use "Transaction" mode URL for DATABASE_URL (port 6543, pgBouncer pooler)
# Use "Session" mode URL for DIRECT_URL (port 5432, direct connection)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ── NextAuth ──────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
NEXTAUTH_SECRET="your-secret-min-32-chars-replace-this"
# Local: http://localhost:3000 | Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ── Razorpay ─────────────────────────────────────────────────────
# Test keys: dashboard.razorpay.com → Settings → API Keys → Generate Test Key
# Live keys: dashboard.razorpay.com → Settings → API Keys → Generate Live Key
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret_here"
# Must match RAZORPAY_KEY_ID — exposed to browser for Razorpay checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxxxx"

# ── Resend (Email) ────────────────────────────────────────────────
# Get key: resend.com → API Keys → Create API Key
# Free tier: 3,000 emails/month, must verify domain for custom From address
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Must be from a verified domain in Resend (or use onboarding@resend.dev for testing)
FROM_EMAIL="greenlegacy@jitomumbai.org"
FROM_NAME="JITO Green Legacy"

# ── Application URLs ─────────────────────────────────────────────
# Local: http://localhost:3000 | Production: https://yourdomain.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

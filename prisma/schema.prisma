// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")  // Uncomment only when using Supabase pgBouncer on Vercel
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  mobile        String?
  address       String?
  pan           String?
  password      String?
  role          Role      @default(DONOR)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  donations  Donation[]
  accounts   Account[]
  sessions   Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  treePrice   Float    @default(500)
  active      Boolean  @default(true)
  imageUrl    String?
  goal        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  donations Donation[]

  @@map("campaigns")
}

model Donation {
  id               String          @id @default(cuid())
  userId           String?
  campaignId       String
  amount           Float
  numberOfTrees    Int
  donorName        String
  donorEmail       String
  donorMobile      String?
  donorAddress     String?
  donorPan         String?
  donorChapter     String?
  dedicationName   String?
  dedicationType   DedicationType?
  paymentStatus    PaymentStatus   @default(PENDING)
  paymentGatewayId String?
  paymentOrderId   String?
  paymentMethod    String?
  receiptNumber    String?         @unique
  certificateUrl   String?
  receiptUrl       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user        User?       @relation(fields: [userId], references: [id])
  campaign    Campaign    @relation(fields: [campaignId], references: [id])
  trees       Tree[]
  receipt     Receipt?
  certificate Certificate?

  @@map("donations")
}

model Tree {
  id          String     @id @default(cuid())
  donationId  String
  treeTagId   String?    @unique
  species     String?
  geoLatitude Float?
  geoLongitude Float?
  plantedDate DateTime?
  imageUrl    String?
  status      TreeStatus @default(PENDING)
  expectedCO2 Float?
  siteId      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  donation       Donation        @relation(fields: [donationId], references: [id])
  plantationSite PlantationSite? @relation(fields: [siteId], references: [id])

  @@map("trees")
}

model PlantationSite {
  id          String   @id @default(cuid())
  siteName    String
  location    String
  acreage     Float?
  partnerName String?
  geoData     Json?
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  trees Tree[]

  @@map("plantation_sites")
}

model Receipt {
  id            String   @id @default(cuid())
  donationId    String   @unique
  receiptPdfUrl String?
  generatedAt   DateTime @default(now())

  donation Donation @relation(fields: [donationId], references: [id])

  @@map("receipts")
}

model Certificate {
  id                String   @id @default(cuid())
  donationId        String   @unique
  certificatePdfUrl String?
  generatedAt       DateTime @default(now())

  donation Donation @relation(fields: [donationId], references: [id])

  @@map("certificates")
}

enum Role {
  DONOR
  ADMIN
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DedicationType {
  MOTHER
  FATHER
  GRANDPARENTS
  DAUGHTER
  MEMORIAL
  CSR
  OTHER
}

enum TreeStatus {
  PENDING
  PLANTED
  GROWING
  MATURE
}
